# ── Backend (.env en el VPS) ──────────────────────────────────────
PORT=3000
NODE_ENV=production

# Base de datos (Supabase — igual que en local)
DATABASE_URL=postgresql://postgres.XXXXXXXX:PASSWORD@aws-1-eu-west-1.pooler.supabase.com:5432/postgres

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Evolution API — apunta al propio VPS (localhost dentro del VPS)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=CAMBIA_ESTO_POR_KEY_SEGURA
EVOLUTION_INSTANCE=prueba-personal   # instancia para tu WhatsApp de prueba

WEBHOOK_SECRET=

# ── docker-compose.prod.yml — variables de entorno ───────────────
VPS_IP=TU_IP_PUBLICA_AQUI
EVOLUTION_API_KEY=CAMBIA_ESTO_POR_KEY_SEGURA   # misma que arriba
EVOLUTION_DB_PASS=CAMBIA_ESTO_POR_PASSWORD_SEGURO
