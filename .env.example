# ============================================
# BOTVENTAS AI - Variables de Entorno
# Copia este archivo como .env y completa los valores
# ============================================

# Servidor
PORT=3000
NODE_ENV=development

# Base de Datos PostgreSQL
DATABASE_URL=postgresql://usuario:password@localhost:5432/botventas

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=tu-api-key-aqui
EVOLUTION_INSTANCE=botventas

# Webhook
WEBHOOK_SECRET=un-secreto-seguro-aqui

# Google Calendar (opcional — para agendamiento automático de citas)
# 1. Google Cloud Console → IAM → Service Accounts → Crear cuenta de servicio
# 2. Descargar clave JSON
# 3. Compartir tu Google Calendar con el email de la service account (permisos "Hacer cambios en eventos")
GOOGLE_CALENDAR_ID=primary
GOOGLE_SERVICE_ACCOUNT_EMAIL=bot@tu-proyecto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXX...\n-----END PRIVATE KEY-----\n"
